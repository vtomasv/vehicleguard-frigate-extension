# ─────────────────────────────────────────────────────────────────────────────
# VehicleGuard — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=vehicleguard123
DB_ROOT_PASSWORD=rootpassword

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-to-a-long-random-string-in-production

# ── Manus OAuth (Authentication) ─────────────────────────────────────────────
# Required for user login. Get these from https://manus.im
# If you don't have a Manus account, the app will still work but auth is disabled.
VITE_APP_ID=
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://manus.im
OWNER_OPEN_ID=
OWNER_NAME=admin

# ── Manus Forge LLM (Default AI Provider) ────────────────────────────────────
# Default LLM provider used if no custom config is set in the app.
# Get these from your Manus project settings.
# You can also configure OpenAI / Anthropic / Gemini / Ollama directly in the app UI.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# ── S3 Storage ────────────────────────────────────────────────────────────────
# For local development, MinIO is included in docker-compose (runs on port 9000).
# For production, use AWS S3 or any S3-compatible service.
#
# MinIO local (default):
S3_ENDPOINT=http://minio:9000
S3_BUCKET=vehicleguard
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_REGION=us-east-1
#
# AWS S3 (production example):
# S3_ENDPOINT=
# S3_BUCKET=my-vehicleguard-bucket
# S3_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
# S3_SECRET_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# S3_REGION=us-east-1

# ── Custom LLM (Optional — can also be set in app UI) ────────────────────────
# These are overridden by the in-app LLM configuration (Settings → APIs y Modelos).
# You can pre-configure them here for automated deployments.
#
# OpenAI:
# OPENAI_API_KEY=sk-...
#
# Anthropic:
# ANTHROPIC_API_KEY=sk-ant-...
#
# Google Gemini:
# GEMINI_API_KEY=AIza...
#
# Ollama (local, no key needed):
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
