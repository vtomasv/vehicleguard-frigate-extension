# ─────────────────────────────────────────────────────────────────────────────
# VehicleGuard — Environment Variables
# Copy this file to .env and fill in your values
#
# Quick start:
#   cp .env.example .env
#   docker compose up -d
#   docker compose exec app node seed-admin.mjs
#   → Login at http://localhost:3000 with admin@vehicleguard.local / admin123
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=vehicleguard123
DB_ROOT_PASSWORD=rootpassword

# ── Authentication ────────────────────────────────────────────────────────────
# AUTH_MODE=local → standalone mode with email/password (no Manus OAuth required)
# AUTH_MODE=manus → use Manus OAuth (requires VITE_APP_ID and related vars below)
AUTH_MODE=local
VITE_AUTH_MODE=local

# Generate a secure secret with: openssl rand -base64 32
JWT_SECRET=change-me-to-a-long-random-string-in-production

# ── Admin User (created by seed-admin.mjs) ────────────────────────────────────
# Change these before running seed-admin.mjs for the first time
ADMIN_EMAIL=admin@vehicleguard.local
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrador

# ── S3 Storage (MinIO — included in docker-compose) ──────────────────────────
# MinIO runs locally on port 9000. Console available at http://localhost:9001
S3_ENDPOINT=http://minio:9000
S3_BUCKET=vehicleguard
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
#
# AWS S3 (production alternative):
# S3_ENDPOINT=
# S3_BUCKET=my-vehicleguard-bucket
# S3_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
# S3_SECRET_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# S3_REGION=us-east-1

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Configure your preferred LLM provider here OR via the app UI (Settings → APIs y Modelos).
# The in-app configuration takes precedence over these environment variables.
#
# Option 1 — OpenAI (recommended for best results):
# OPENAI_API_KEY=sk-...
#
# Option 2 — Anthropic Claude:
# ANTHROPIC_API_KEY=sk-ant-...
#
# Option 3 — Google Gemini:
# GEMINI_API_KEY=AIza...
#
# Option 4 — Ollama (local, no key needed — runs on host machine):
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
#
# Option 5 — Manus Forge (only if you have a Manus account):
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ── Manus OAuth (only needed if AUTH_MODE=manus) ─────────────────────────────
# Leave blank when using AUTH_MODE=local (default)
# VITE_APP_ID=
# OAUTH_SERVER_URL=https://api.manus.im
# VITE_OAUTH_PORTAL_URL=https://manus.im
# OWNER_OPEN_ID=
OWNER_NAME=admin
